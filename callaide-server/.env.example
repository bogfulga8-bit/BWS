# CallAide Server Configuration
# Copy this to .env and fill in your API keys

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Deepgram (STT)
DEEPGRAM_API_KEY=

# LLM Provider (OpenAI or Anthropic)
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL_LIVE=gpt-4o-mini
LLM_MODEL_SETUP=gpt-4o

# TTS (ElevenLabs or Cartesia)
ELEVENLABS_API_KEY=
# CARTESIA_API_KEY=
TTS_PROVIDER=elevenlabs
TTS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Database
DATABASE_URL=sqlite:///./callaide.db

# Notifications
SENDGRID_API_KEY=
FROM_EMAIL=noreply@callaide.com

# Webhook Security
WEBHOOK_SECRET=